APP_NAME=IA Facial Enterprise MVP
ENVIRONMENT=production
API_V1_PREFIX=/api/v1
# Incluye origenes del dashboard local (5500) y la IP/dominio del VPS
CORS_ORIGINS=["http://104.238.215.26","http://127.0.0.1:5500","http://localhost:5500","http://localhost:3000","http://localhost:5173","http://127.0.0.1:5173"]
DEEPFACE_MODEL=Facenet512
DEEPFACE_DETECTOR_BACKEND=opencv
FACE_ENGINE=deepface
# deepface | arcface | insightface
# arcface = DeepFace ArcFace (Windows OK). insightface = buffalo_l (Linux/WSL o MSVC en Windows).
INSIGHTFACE_MODEL=buffalo_l
FACE_MATCH_THRESHOLD=0.35
FACE_SCAN_MATCH_THRESHOLD=0.52
LIVENESS_MAX_SAME_PERSON_DISTANCE=0.42
LIVENESS_MIN_FACE_SHIFT_PX=18
LIVENESS_EAR_BLINK_MAX=0.21
LIVENESS_EAR_OPEN_MIN=0.22
LIVENESS_MIN_HEAD_YAW_DELTA=0.08
LIVENESS_MIN_TEXTURE_SCORE=12
LIVENESS_MIN_ANTI_SPOOF_SCORE=0.30
LIVENESS_MIN_PASS_SCORE=0.72
LIVENESS_MAR_OPEN_MIN=0.28
LIVENESS_SMILE_ENABLED=true
DEFAULT_SCHEDULED_EXIT_TIME=22:00
DEFAULT_EXIT_TOLERANCE_MINUTES=10
OLLAMA_ENABLED=false
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1
MAX_UPLOAD_MB=8
LOCAL_DATA_DIR=./data
STORAGE_BACKEND=supabase
DEFAULT_ORG_CODE=demo
DATABASE_URL=postgresql+psycopg://ia_facial:ia_facial@localhost:5432/ia_facial
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
R2_ACCOUNT_ID=
R2_ENDPOINT=https://<ACCOUNT_ID>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=ia-facial-images
R2_PUBLIC_BASE_URL=
# VPS Kamatera
GMAIL_TOKEN_PATH=/root/ia_facial/backend/token.json
